{
  "db_path": "data/craigslist_cars.sqlite",
  "schema": "craigslist_cars",
  "select": ["id", "title", "price", "url"],
  "where": [
    {"field": "price", "op": ">=", "value": 5000},
    {"field": "region", "op": "like", "value": "%toronto%"}
  ],
  "order_by": [
    {"field": "price", "direction": "asc"}
  ]
}
