{
  "openapi": "3.0.3",
  "info": {
    "title": "{{api_name}}",
    "version": "{{api_version}}",
    "description": "{{api_description}}"
  },
  "servers": [
    {
      "url": "{{base_url}}"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service healthy"
          }
        }
      }
    },
    "/schemas": {
      "get": {
        "summary": "List available schemas",
        "responses": {
          "200": {
            "description": "Schema list"
          }
        }
      }
    },
    "/v1/collections/{{collection}}/search": {
      "post": {
        "summary": "Search {{collection}} collection",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SearchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Search response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SearchRequest": {
        "type": "object",
        "properties": {
          "select": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "filter": {
            "type": "object",
            "description": "Filter object that maps field names to values or operators."
          },
          "order_by": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "limit": {
            "type": "integer",
            "default": 100
          },
          "offset": {
            "type": "integer",
            "default": 0
          }
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "metadata": {
            "type": "object"
          }
        }
      }
    }
  }
}
